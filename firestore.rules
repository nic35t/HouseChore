rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    match /artifacts/{appId}/public/data/settings/{settingId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /artifacts/{appId}/public/data/chores/{choreId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.keys().hasOnly([
          'date',
          'name',
          'detail',
          'zone',
          'points',
          'uid',
          'createdAt'
        ])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.date is string
        && request.resource.data.name is string
        && request.resource.data.detail is string
        && request.resource.data.zone is string
        && request.resource.data.points is int
        && request.resource.data.points >= 0
        && request.resource.data.points <= 1440
        && request.resource.data.createdAt is int;

      allow update: if false;
      allow delete: if isAdmin() || (isSignedIn() && resource.data.uid == request.auth.uid);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
